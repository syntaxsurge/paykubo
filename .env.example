# EIP-712 payment token metadata used for x402 signatures.
NEXT_PUBLIC_PAYMENT_TOKEN_NAME=USDC
NEXT_PUBLIC_PAYMENT_TOKEN_SYMBOL=USDC
NEXT_PUBLIC_PAYMENT_TOKEN_VERSION=2
NEXT_PUBLIC_PAYMENT_TOKEN_DECIMALS=6
# The configured facilitator serves x402 under this path; the bare domain may not expose the API.
# GET /supported is public. POST /verify and /settle require HMAC keys.
# Get Morph x402 keys from: https://morph-rails-hoodi.morph.network/x402
X402_FACILITATOR_URL=https://morph-rails-hoodi.morph.network/x402/v2
X402_FACILITATOR_ACCESS_KEY=
X402_FACILITATOR_SECRET_KEY=

AGENT_SPENDER_PRIVATE_KEY=
