NEXT_PUBLIC_APP_NAME=Paykubo
NEXT_PUBLIC_APP_DESCRIPTION=USDC-native API commerce for humans, applications, and AI agents.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONVEX_URL=

CONVEX_DEPLOYMENT=
# Generate with: openssl rand -hex 32
CONVEX_RESET_TOKEN=
CONVEX_RESET_BATCH=128

# Marketing redirects (Next.js `redirects()` in `next.config.js`)
DEMO_VIDEO_URL=
PITCH_DECK_URL=

NEXT_PUBLIC_WALLET_PROVIDER=rainbowkit
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ADMIN_WALLET_ADDRESSES=0x7CE33579392AEAF1791c9B0c8302a502B5867688
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=0x07870EbBE687D98F5636b66c26e4005A854B8921
NEXT_PUBLIC_AGENT_ATTESTOR_ADDRESS=0xB031aCC58b182e34262FC7903d05e62AD30a48C8
NEXT_PUBLIC_AGENT_RUN_VAULT_ADDRESS=0xDcC0FB6e9061e25BCd1042227777F37d124b670f
NEXT_PUBLIC_API_PAYMENT_ESCROW_ADDRESS=0x8D875d4596f3BaA32552A5bf094f60446C864970
NEXT_PUBLIC_SUBSCRIPTION_CHAIN_ID=2910
NEXT_PUBLIC_SUBSCRIPTION_BASE_PRICE_WEI=1000000000000000
NEXT_PUBLIC_SUBSCRIPTION_PLUS_PRICE_WEI=2000000000000000

NEXT_PUBLIC_EVM_CHAIN_ID=2910
NEXT_PUBLIC_EVM_CHAIN_NAME=Morph Hoodi Testnet
NEXT_PUBLIC_EVM_CHAIN_SHORT_NAME=Morph Hoodi
NEXT_PUBLIC_EVM_RPC_URL=https://rpc-hoodi.morph.network
NEXT_PUBLIC_EVM_EXPLORER_NAME=Morph Hoodi Explorer
NEXT_PUBLIC_EVM_EXPLORER_URL=https://explorer-hoodi.morph.network
NEXT_PUBLIC_EVM_NATIVE_CURRENCY_NAME=Ether
NEXT_PUBLIC_EVM_NATIVE_CURRENCY_SYMBOL=ETH
NEXT_PUBLIC_EVM_NATIVE_CURRENCY_DECIMALS=18
NEXT_PUBLIC_EVM_IS_TESTNET=true
NEXT_PUBLIC_X402_NETWORK=eip155:2910
NEXT_PUBLIC_PAYMENT_TOKEN_ADDRESS=0x7433b41C6c5e1d58D4Da99483609520255ab661B
# EIP-712 payment token metadata used for x402 signatures.
NEXT_PUBLIC_PAYMENT_TOKEN_NAME=USDC
NEXT_PUBLIC_PAYMENT_TOKEN_SYMBOL=USDC
NEXT_PUBLIC_PAYMENT_TOKEN_LABEL=Stablecoin
NEXT_PUBLIC_PAYMENT_TOKEN_VERSION=2
NEXT_PUBLIC_PAYMENT_TOKEN_DECIMALS=6
# Use eip3009 for tokens that support transferWithAuthorization; use permit2 for standard ERC-20 approve + Permit2 flows.
NEXT_PUBLIC_PAYMENT_TOKEN_TRANSFER_METHOD=eip3009
# The configured facilitator serves x402 under this path; the bare domain may not expose the API.
# GET /supported is public. POST /verify and /settle require HMAC keys.
# Get Morph x402 keys from: https://morph-rails-hoodi.morph.network/x402
X402_FACILITATOR_URL=https://morph-rails-hoodi.morph.network/x402/v2
X402_FACILITATOR_ACCESS_KEY=
X402_FACILITATOR_SECRET_KEY=

AGENT_SPENDER_PRIVATE_KEY=
AGENT_ATTESTER_PRIVATE_KEY=
API_ESCROW_OPERATOR_PRIVATE_KEY=
AGENT_RUN_VAULT_OPERATOR_PRIVATE_KEY=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=gpt-5.2
