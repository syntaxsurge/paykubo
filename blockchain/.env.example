# Admin and platform roles
ADMIN_ADDRESS=
PLATFORM_ADDRESS=

# Comma-separated list of issuer addresses (optional)
ISSUER_ADDRESSES=

# Subscription prices in wei (denominated in the target chain native token)
SUBSCRIPTION_PRICE_WEI_BASE=1000000000000000
SUBSCRIPTION_PRICE_WEI_PLUS=2000000000000000

# Deployer private key
PRIVATE_KEY=

# Deployment target
EVM_CHAIN_ID=2910
EVM_RPC_URL=https://rpc-hoodi.morph.network
