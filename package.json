{
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:code": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,cts,mts,json,css,scss,mdx,html}\"",
    "lint:all": "pnpm run lint:fix && pnpm run lint && pnpm run format:code",
    "typecheck": "node -e \"require('fs').rmSync('.next/types',{recursive:true,force:true})\" && tsc --noEmit",
    "convex:dev": "node ./scripts/convex-dev.cjs",
    "convex:deploy": "npx convex deploy -y",
    "convex:redeploy": "pnpm run convex:deploy && pnpm run convex:dev",
    "convex:reset": "dotenv -e .env.local -- tsx scripts/reset-convex.ts",
    "seed:admin-tools": "dotenv -e .env.local -- tsx scripts/seed-admin-tools.ts",
    "contracts:deploy": "tsx scripts/deploy-contracts.ts",
    "contracts:deploy:agent": "pnpm --dir blockchain deploy:agent-attestor",
    "contracts:deploy:api-escrow": "pnpm --dir blockchain deploy:api-escrow",
    "x402:call": "tsx scripts/x402-paid-call.ts"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@scalar/nextjs-api-reference": "^0.10.14",
    "@tailwindcss/postcss": "4.1.7",
    "@tanstack/react-query": "^5.84.1",
    "@x402/core": "^2.12.0",
    "@x402/evm": "^2.12.0",
    "@x402/express": "^2.12.0",
    "@x402/fetch": "^2.12.0",
    "@x402/paywall": "^2.12.0",
    "clsx": "^2.1.1",
    "convex": "^1.31.2",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "next": "15.5.9",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "4.1.7",
    "thirdweb": "^5.105.26",
    "viem": "^2.43.3",
    "wagmi": "^2.16.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/node": "^22.17.0",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.32.0",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
